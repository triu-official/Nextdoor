{
  "name": "nextdoor",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:server": "npm run dev -w backend",
    "dev:client": "npm run dev -w frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
